{
  "annotations": { "list": [] },
  "description": "Cluster-wide image health audit — availability, pre-release age, version spread, credential validity, and digest pinning",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Unavailable Images",
      "description": "Total images that cannot be reached in their registry. Cluster-wide — not affected by namespace filter.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(kube_image_total_unavailable{job=\"__KUBEIC_CHECKER_JOB__\", exported_namespace=~\"$namespace\", cluster=~\"$cluster\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "title": "Invalid Credentials",
      "description": "Registry credentials that failed authentication testing. Zero is healthy.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(kube_image_credential_valid{job=\"__KUBEIC_CHECKER_JOB__\", exported_namespace=~\"$namespace\", cluster=~\"$cluster\"} == 0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "title": "Pre-release Violations",
      "description": "Pre-release images (alpha, beta, rc, dev, latest, etc.) running beyond the max age threshold. Cluster-wide total.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "max(kube_image_total_prerelease_violations{job=\"__KUBEIC_OPERATOR_JOB__\", cluster=~\"$cluster\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "title": "Spread Violations",
      "description": "Image bases running more distinct versions than the configured threshold. Cluster-wide total.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "max(kube_image_total_spread_violations{job=\"__KUBEIC_OPERATOR_JOB__\", cluster=~\"$cluster\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "title": "Digest Mismatches",
      "description": "Images where the running pod's pinned digest no longer matches the registry digest. Zero is healthy.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(kube_image_digest_match{job=\"__KUBEIC_CHECKER_JOB__\", exported_namespace=~\"$namespace\", cluster=~\"$cluster\"} == 0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "title": "Unavailable Images",
      "description": "Pods with images that failed skopeo inspect — no longer reachable in their registry",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "kube_image_available{job=\"__KUBEIC_CHECKER_JOB__\", exported_namespace=~\"$namespace\", registry=~\"$registry\", image_name=~\"$image_name\", cluster=~\"$cluster\"} == 0",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": false } },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Value": true,
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "endpoint": true,
              "cluster": true,
              "container": true,
              "pod": true,
              "namespace": true,
              "service": true,
              "registry": true,
              "image_name": true
            },
            "renameByName": {
              "exported_namespace": "Namespace",
              "exported_pod": "Pod",
              "exported_container": "Container",
              "image": "Image"
            }
          }
        }
      ]
    },
    {
      "title": "Pre-release Images",
      "description": "Pre-release images currently running. Tag shown separately. Age column color: green < 3d, yellow >= 3d, red >= 7d.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "kube_image_prerelease_age_days{job=\"__KUBEIC_OPERATOR_JOB__\", exported_namespace=~\"$namespace\", registry=~\"$registry\", image_name=~\"$image_name\", cluster=~\"$cluster\"} > 0",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Age (days)" },
            "properties": [
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 3 },
                    { "color": "red", "value": 7 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "unit",
                "value": "d"
              }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": false } },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Value": true,
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "endpoint": true,
              "cluster": true,
              "container": true,
              "pod": true,
              "namespace": true,
              "service": true,
              "registry": true,
              "image_name": true,
              "image": true
            },
            "renameByName": {
              "exported_namespace": "Namespace",
              "exported_pod": "Pod",
              "exported_container": "Container",
              "image_name": "Image",
              "tag": "Tag",
              "Value": "Age (days)"
            }
          }
        }
      ]
    },
    {
      "title": "Distinct Versions per Image",
      "description": "Number of different tags running for each image base. Red threshold at the configured spread limit.",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "kube_image_version_count{job=\"__KUBEIC_OPERATOR_JOB__\", exported_namespace=~\"$namespace\", registry=~\"$registry\", image_name=~\"$image_name\", cluster=~\"$cluster\"}",
          "format": "instant",
          "instant": true,
          "legendFormat": "{{image_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 4 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stacking": "none",
        "tooltip": { "mode": "single" }
      }
    },
    {
      "title": "Version Spread Over Time",
      "description": "Number of distinct versions per image base over time — highlights when drift started",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "kube_image_version_count{job=\"__KUBEIC_OPERATOR_JOB__\", exported_namespace=~\"$namespace\", registry=~\"$registry\", image_name=~\"$image_name\", cluster=~\"$cluster\"}",
          "legendFormat": "{{image_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 4 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      }
    },
    {
      "title": "Registry Credential Status",
      "description": "All registry credentials tested by the checkers. Shows both valid and invalid so you always have visibility.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "kube_image_credential_valid{job=\"__KUBEIC_CHECKER_JOB__\", exported_namespace=~\"$namespace\", registry=~\"$registry\", cluster=~\"$cluster\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "displayName",
                "value": "Status"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "Invalid", "color": "red" },
                      "1": { "text": "Valid", "color": "green" }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "custom.align",
                "value": "center"
              }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": false } },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "endpoint": true,
              "cluster": true,
              "container": true,
              "pod": true,
              "namespace": true,
              "service": true
            },
            "renameByName": {
              "exported_namespace": "Namespace",
              "registry": "Registry",
              "secret_name": "Secret"
            }
          }
        }
      ]
    },
    {
      "title": "Digest Pin Status",
      "description": "Images checked for digest pin drift. Match = running digest matches registry, Mismatch = image has been repushed or replaced.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "kube_image_digest_match{job=\"__KUBEIC_CHECKER_JOB__\", exported_namespace=~\"$namespace\", registry=~\"$registry\", image_name=~\"$image_name\", cluster=~\"$cluster\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "displayName",
                "value": "Digest Status"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "Mismatch", "color": "red" },
                      "1": { "text": "Match", "color": "green" }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "custom.align",
                "value": "center"
              }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": false } },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "endpoint": true,
              "cluster": true,
              "namespace": true,
              "service": true,
              "registry": true,
              "image_name": true
            },
            "renameByName": {
              "exported_namespace": "Namespace",
              "exported_pod": "Pod",
              "exported_container": "Container",
              "image": "Image"
            }
          }
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["kubernetes", "image-audit", "operator"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kube_image_available{job=\"__KUBEIC_CHECKER_JOB__\"}, cluster)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Cluster",
        "multi": true,
        "name": "cluster",
        "options": [],
        "query": "label_values(kube_image_available{job=\"__KUBEIC_CHECKER_JOB__\"}, cluster)",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kube_image_available{job=\"__KUBEIC_CHECKER_JOB__\", cluster=~\"$cluster\"}, exported_namespace)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Namespace",
        "multi": true,
        "name": "namespace",
        "options": [],
        "query": "label_values(kube_image_available{job=\"__KUBEIC_CHECKER_JOB__\", cluster=~\"$cluster\"}, exported_namespace)",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kube_image_available{job=\"__KUBEIC_CHECKER_JOB__\", cluster=~\"$cluster\", exported_namespace=~\"$namespace\"}, registry)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Registry",
        "multi": true,
        "name": "registry",
        "options": [],
        "query": "label_values(kube_image_available{job=\"__KUBEIC_CHECKER_JOB__\", cluster=~\"$cluster\", exported_namespace=~\"$namespace\"}, registry)",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kube_image_available{job=\"__KUBEIC_CHECKER_JOB__\", cluster=~\"$cluster\", exported_namespace=~\"$namespace\", registry=~\"$registry\"}, image_name)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Image",
        "multi": true,
        "name": "image_name",
        "options": [],
        "query": "label_values(kube_image_available{job=\"__KUBEIC_CHECKER_JOB__\", cluster=~\"$cluster\", exported_namespace=~\"$namespace\", registry=~\"$registry\"}, image_name)",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"] },
  "title": "Cluster Image Health",
  "uid": "image-audit",
  "version": 1
}
